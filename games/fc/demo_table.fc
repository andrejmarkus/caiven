-- Table demo: create, read, write table fields and indices

let t = 0
let score = 0
let frame = 0

init:
  t = {x=60, y=60, dx=1, dy=1}

loop:
  cls()

  -- bounce dx/dy off walls
  if t.x >= 120 then
    t.dx = -1
  end
  if t.x <= 0 then
    t.dx = 1
  end
  if t.y >= 80 then
    t.dy = -1
  end
  if t.y <= 0 then
    t.dy = 1
  end

  -- update position
  t.x += t.dx
  t.y += t.dy

  score += 1

  num(2, 2, score, 7)
  wait()
