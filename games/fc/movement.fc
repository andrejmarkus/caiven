-- Simple movement demo in fc-lang
-- Draw sprite 0 in the sprite editor (F2) to see the player
const SPEED = 2

let x = 60
let y = 60

init:
  pal(0, 10, 10, 30)

loop:
  cls()
  if btn(0) then
    y -= SPEED
  end
  if btn(1) then
    y += SPEED
  end
  if btn(2) then
    x -= SPEED
  end
  if btn(3) then
    x += SPEED
  end
  spr(0, x, y)
  wait()
